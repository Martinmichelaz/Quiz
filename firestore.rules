rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - displayName: string (required) - User's display name
    //   - photoURL: string (optional) - User's avatar URL
    //   - score: number (required) - Total points earned
    //   - progress: number (required) - Index of the current question
    //   - lastActive: string (optional) - ISO date string
    //   - role: string (optional) - User role (admin/user)
    //
    // Collection: users/{userId}/private/settings
    // Fields:
    //   - email: string (required) - User's private email
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "maromichel2020@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'displayName', 'photoURL', 'score', 'progress', 'lastActive', 'role'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['uid', 'displayName', 'score', 'progress']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.score is number && data.score >= 0 &&
             data.progress is number && data.progress >= 0 &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastActive' in data) || data.lastActive is string) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Public profile access
      allow read: if isAuthenticated();
      
      // Profile management
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user');
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    (request.resource.data.role == resource.data.role || (resource.data.role == 'admin' && isAdmin()));
      
      allow delete: if isAdmin();

      // Private data subcollection
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Connection test collection
    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
